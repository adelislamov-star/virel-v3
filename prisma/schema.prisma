// ============================================
// PHASE 2 — DISTRICTS & TRANSPORT (SEO GEO)
// ============================================

model District {
  id             String          @id @default(cuid())
  name           String          @unique  // "Mayfair"
  slug           String          @unique  // "mayfair"
  tier           Int             @default(1)  // 1=top, 2=high, 3=medium
  description    String?         @db.Text
  hotels         String[]
  restaurants    String[]
  landmarks      String[]
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  isActive       Boolean         @default(true)
  isPopular      Boolean         @default(false)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  transportHubs  TransportHub[]
  modelLocations ModelLocation[]

  @@map("districts")
}

model TransportHub {
  id             String   @id @default(cuid())
  name           String   @unique  // "Bond Street"
  slug           String   @unique  // "bond-street"
  districtId     String
  walkingMinutes Int      @default(5)
  description    String?  @db.Text
  seoTitle       String?
  seoDescription String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  district       District @relation(fields: [districtId], references: [id])

  @@map("transport_hubs")
}

model ModelLocation {
  id             String   @id @default(cuid())
  modelId        String
  districtId     String
  isPrimary      Boolean  @default(false)
  transportHubId String?
  walkingMinutes Int?
  model          Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
