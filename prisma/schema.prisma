  @@index([sourceModule])
  @@index([entityType, entityId])
  @@index([dedupeKey])
  @@map("operations_feed_items")
}

// ============================================
// JOB QUEUE
// ============================================

model JobQueue {
  id              String    @id @default(cuid())
  // type values: send_email, send_telegram, send_sms, generate_report, fraud_scan,
  //   media_processing, seo_generation, pricing_recalculation, retention_scan,
  //   membership_billing, notification_dispatch
  type            String
  payloadJson     Json      @map("payload_json")
  dedupeKey       String?   @map("dedupe_key")
  // status values: queued, running, succeeded, failed, dead_letter, cancelled
  status          String    @default("queued")
  // priority values: critical, high, normal, low
  priority        String    @default("normal")
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3)  @map("max_attempts")
  workerName      String?   @map("worker_name")
  parentJobId     String?   @map("parent_job_id")
  lockToken       String?   @map("lock_token")
  lockedAt        DateTime? @map("locked_at")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")
  scheduledAt     DateTime  @default(now())  @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  failedAt        DateTime? @map("failed_at")
  errorText       String?   @db.Text  @map("error_text")
  createdAt       DateTime  @default(now())  @map("created_at")
  updatedAt       DateTime  @updatedAt       @map("updated_at")

  logs            JobLog[]

  @@index([status, priority])
  @@index([type])
  @@index([scheduledAt])
  @@index([dedupeKey])
  @@index([parentJobId])
  @@map("job_queue")
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  job       JobQueue @relation(fields: [jobId], references: [id])
  step      String
  status    String
  message   String   @db.Text
  createdAt DateTime @default(now())  @map("created_at")

  @@index([jobId])
  @@map("job_logs")
}

// ============================================
// NOTIFICATIONS ENGINE
// ============================================

model NotificationTemplate {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  channel           String
  eventType         String    @map("event_type")
