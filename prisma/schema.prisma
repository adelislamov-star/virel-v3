generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                     @id @default(cuid())
  email                String                     @unique
  phone                String?
  name                 String
  passwordHash         String
  status               String                     @default("active")
  lastLoginAt          DateTime?
  telegramChatId       String?
  twoFactorSecret      String?
  twoFactorEnabled     Boolean                    @default(false)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  auditLogs            AuditLog[]
  assignedBookings     Booking[]                  @relation("AssignedBookings")
  assignedInquiries    Inquiry[]                  @relation("AssignedInquiries")
  createdPayments      Payment[]                  @relation("CreatedPayments")
  sessions             Session[]
  performanceSnapshots StaffPerformanceSnapshot[]
  scoreSnapshots       StaffScoreSnapshot[]
  assignedTasks        Task[]                     @relation("AssignedTasks")
  roles                UserRole[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model Model {
  id                     String                   @id @default(cuid())
  publicCode             String                   @unique
  name                   String
  slug                   String                   @unique
  primaryLocationId      String?
  status                 String                   @default("draft")
  visibility             String                   @default("public")
  ratingInternal         Float?
  notesInternal          String?
  aiParseExampleId       String?
  dataCompletenessScore  Int                      @default(0)
  modelRiskIndex         String                   @default("green")
  deletedAt              DateTime?                @map("deleted_at")
  deletedBy              String?                  @map("deleted_by")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  availability           String?
  duoPartnerIds          String[]
  education              String?
  isExclusive            Boolean                  @default(false)
  isVerified             Boolean                  @default(false)
  lastActiveAt           DateTime?
  measurements           String?
  piercingDetails        String[]
  publicTags             String[]
  responseTimeMin        Int?
  seoDescription         String?
  seoTitle               String?
  tagline                String?
  travel                 String?
  verificationNote       String?
  wardrobe               String[]
  ageForWeb              Int?
  availableAllDay        Boolean                  @default(false)
  availableDays          String[]
  bio                    String?
  dateOfBirth            DateTime?
  dinnerDates            Boolean                  @default(false)
  email                  String?
  ethnicity              String?
  flatNumber             String?
  floor                  String?
  hairLength             String?
  hasFlatmates           Boolean                  @default(false)
  houseNumber            String?
  internalRating         Float?
  nearestStation         String?
  paymentBTC             Boolean                  @default(false)
  paymentBankTransfer    Boolean                  @default(false)
  paymentCash            Boolean                  @default(false)
  paymentLTC             Boolean                  @default(false)
  paymentMonese          Boolean                  @default(false)
  paymentMonzo           Boolean                  @default(false)
  paymentRevolut         Boolean                  @default(false)
  paymentStarling        Boolean                  @default(false)
  paymentTerminal        Boolean                  @default(false)
  paymentUSDT            Boolean                  @default(false)
  phone                  String?
  phone2                 String?
  postcode               String?
  signal                 Boolean                  @default(false)
  street                 String?
  telegram               Boolean                  @default(false)
  travelCompanion        Boolean                  @default(false)
  viber                  Boolean                  @default(false)
  whatsapp               Boolean                  @default(false)
  willingDisabled        Boolean                  @default(false)
  willingInternational   Boolean                  @default(false)
  willingLongDistance    Boolean                  @default(false)
  willingPrivatePlaces   Boolean                  @default(false)
  workingName            String?
  worksWithCouples       Boolean                  @default(false)
  worksWithWomen         Boolean                  @default(false)
  lastViewedAt           DateTime?
  viewsToday             Int                      @default(0)
  viewsTotal             Int                      @default(0)
  telegramPhone          String?
  telegramTag            String?
  offeredOffers          AlternativeOffer[]       @relation("OfferedModel")
  requestedOffers        AlternativeOffer[]       @relation("RequestedModel")
  availabilityConflicts  AvailabilityConflict[]
  availabilityMismatches AvailabilityMismatch[]
  availabilitySlots      AvailabilitySlot[]
  bookings               Booking[]
  fraudSignals           FraudSignal[]
  incidents              Incident[]               @relation("ModelIncidents")
  inquiryMatches         InquiryMatch[]
  attributes             ModelAttribute[]
  modelAvailabilities    ModelAvailability[]
  categories             ModelCategory[]
  modelLocations         ModelLocation[]
  media                  ModelMedia[]
  modelRates             ModelRate[]
  services               ModelService[]
  similaritiesAsA        ModelSimilarity[]        @relation("ModelSimilarityA")
  similaritiesAsB        ModelSimilarity[]        @relation("ModelSimilarityB")
  stats                  ModelStats?
  aiParseExample         AIParseExample?          @relation(fields: [aiParseExampleId], references: [id])
  primaryLocation        Location?                @relation("PrimaryLocation", fields: [primaryLocationId], references: [id])
  payments               Payment[]
  quickUploadLogs        QuickUploadLog[]
  complaintPatterns      ReviewComplaintPattern[]
  reviews                Review[]

  @@index([status])
  @@index([visibility])
  @@index([primaryLocationId])
  @@map("models")
}

model ModelStats {
  modelId        String   @id
  age            Int?
  height         Int?
  weight         Int?
  dressSize      String?
  feetSize       String?  @map("feet_size")
  bustSize       String?
  bustType       String?
  hairColour     String?
  eyeColour      String?
  smokingStatus  String?
  tattooStatus   String?
  piercingStatus String?
  orientation    String?
  nationality    String?
  languages      String[]
  uniforms       String[]
  model          Model    @relation(fields: [modelId], references: [id])

  @@map("model_stats")
}

model ModelMedia {
  id         String   @id @default(cuid())
  modelId    String
  type       String
  storageKey String
  url        String
  checksum   String?
  isPrimary  Boolean  @default(false)
  isPublic   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  model      Model    @relation(fields: [modelId], references: [id])

  @@index([modelId])
  @@index([modelId, isPrimary])
  @@map("model_media")
}

model ModelService {
  modelId       String
  serviceId     String
  isEnabled     Boolean @default(true)
  extraPrice    Float?
  isExtra       Boolean @default(false)
  isDoublePrice Boolean @default(false)
  isPOA         Boolean @default(false)
  model         Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  service       Service @relation(fields: [serviceId], references: [id])

  @@id([modelId, serviceId])
  @@map("model_services")
}

model ModelCategory {
  modelId    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  model      Model    @relation(fields: [modelId], references: [id])

  @@id([modelId, categoryId])
  @@map("model_categories")
}

model ModelAttribute {
  modelId          String
  attributeValueId String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])
  model            Model          @relation(fields: [modelId], references: [id])

  @@id([modelId, attributeValueId])
  @@map("model_attributes")
}

model Service {
  id                String           @id @default(cuid())
  title             String
  slug              String           @unique
  category          String           @default("Other")
  description       String?
  defaultExtraPrice Float?
  status            String           @default("active")
  isPopular         Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  fullDescription   String?
  introText         String?
  isActive          Boolean          @default(true)
  isPublic          Boolean          @default(true)
  name              String?          @unique
  publicName        String?
  seoDescription    String?
  seoKeywords       String?
  seoTitle          String?
  sortOrder         Int              @default(0)
  bookings          BookingService[]
  models            ModelService[]

  @@map("services")
}

model Category {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  h1              String?
  introHtml       String?
  descriptionHtml String?
  status          String           @default("active")
  isPopular       Boolean          @default(false)
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  models          ModelCategory[]
  content         CategoryContent?

  @@map("categories")
}

model CategoryContent {
  id                String   @id @default(cuid())
  categoryId        String   @unique
  aboutParagraphs   String[]
  standardText      String?
  relatedCategories String[]
  faq               Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  category          Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_content")
}

model Attribute {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  isFilterable Boolean          @default(true)
  isPublic     Boolean          @default(true)
  dataType     String           @default("enum")
  status       String           @default("active")
  values       AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  value       String
  sortOrder   Int              @default(0)
  status      String           @default("active")
  attribute   Attribute        @relation(fields: [attributeId], references: [id])
  models      ModelAttribute[]

  @@unique([attributeId, value])
  @@map("attribute_values")
}

model Location {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  county    String?
  country   String    @default("UK")
  timezone  String    @default("Europe/London")
  latitude  Float?
  longitude Float?
  status    String    @default("active")
  isPopular Boolean   @default(false)
  bookings  Booking[]
  inquiries Inquiry[]
  models    Model[]   @relation("PrimaryLocation")

  @@map("locations")
}

model CallRate {
  id              String  @id @default(cuid())
  locationId      String?
  currency        String  @default("GBP")
  durationMinutes Int
  price           Float
  status          String  @default("active")

  @@map("call_rates")
}

model Client {
  id                         String                  @id @default(cuid())
  fullName                   String?
  email                      String?
  phone                      String?
  preferredChannel           String?
  tags                       String[]
  firstName                  String?                 @map("first_name")
  lastName                   String?                 @map("last_name")
  language                   String?
  city                       String?
  country                    String?
  riskStatus                 String                  @default("normal")
  totalSpent                 Decimal                 @default(0) @db.Decimal(12, 2)
  bookingCount               Int                     @default(0)
  chargebackCount            Int                     @default(0)
  refundCount                Int                     @default(0) @map("refund_count")
  cancellationRate           Decimal                 @default(0) @map("cancellation_rate") @db.Decimal(5, 2)
  notes                      String?
  vipStatus                  String?                 @map("vip_status")
  mergedIntoClientId         String?                 @map("merged_into_client_id")
  deletedAt                  DateTime?               @map("deleted_at")
  deletedBy                  String?                 @map("deleted_by")
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  internalNotes              String?
  lastBookingAt              DateTime?
  marketingOptIn             Boolean                 @default(false)
  preferredCurrency          String?
  preferredDistricts         String[]
  preferredLanguage          String?
  telegramId                 String?
  telegramUsername           String?
  tier                       String?
  totalSpend                 Float?
  wishlistModelIds           String[]
  bookings                   Booking[]
  events                     ClientEvent[]
  identities                 ClientIdentity[]
  membership                 ClientMembership?
  mergeCandidatesAsDuplicate ClientMergeCandidate[]  @relation("MergeDuplicate")
  mergeCandidatesAsPrimary   ClientMergeCandidate[]  @relation("MergePrimary")
  retentionProfile           ClientRetentionProfile?
  riskHistory                ClientRiskHistory[]
  fraudSignals               FraudSignal[]
  incidents                  Incident[]              @relation("ClientIncidents")
  inquiries                  Inquiry[]
  payments                   Payment[]
  retentionActions           RetentionAction[]
  reviews                    Review[]

  @@index([email])
  @@index([phone])
  @@index([riskStatus])
  @@index([mergedIntoClientId])
  @@index([vipStatus])
  @@map("clients")
}

model Inquiry {
  id                  String         @id @default(cuid())
  source              String
  externalRef         String?
  clientId            String?
  status              String         @default("new")
  priority            String         @default("normal")
  subject             String?
  message             String?
  requestedLocationId String?
  requestedServices   Json?
  requestedTimeFrom   DateTime?
  requestedTimeTo     DateTime?
  assignedTo          String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  booking             Booking?
  assignedUser        User?          @relation("AssignedInquiries", fields: [assignedTo], references: [id])
  client              Client?        @relation(fields: [clientId], references: [id])
  requestedLocation   Location?      @relation(fields: [requestedLocationId], references: [id])
  matches             InquiryMatch[]

  @@unique([source, externalRef])
  @@index([status, priority])
  @@index([assignedTo, status])
  @@index([createdAt])
  @@map("inquiries")
}

model InquiryMatch {
  id        String   @id @default(cuid())
  inquiryId String
  modelId   String
  score     Float
  reason    Json
  createdAt DateTime @default(now())
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id])
  model     Model    @relation(fields: [modelId], references: [id])

  @@index([inquiryId])
  @@index([modelId])
  @@map("inquiry_matches")
}

model Booking {
  id              String             @id @default(cuid())
  shortId         String?            @unique
  inquiryId       String?            @unique
  clientId        String
  modelId         String
  locationId      String
  startAt         DateTime
  endAt           DateTime
  status          String             @default("draft")
  bookingType     String             @default("outcall") @map("booking_type")
  priceTotal      Decimal            @db.Decimal(12, 2)
  currency        String             @default("GBP")
  depositRequired Decimal?           @db.Decimal(12, 2)
  depositStatus   String             @default("none")
  paymentStatus   String             @default("unpaid")
  assignedTo      String?
  notesInternal   String?
  deletedAt       DateTime?          @map("deleted_at")
  deletedBy       String?            @map("deleted_by")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  services        BookingService[]
  timeline        BookingTimeline[]
  assignedUser    User?              @relation("AssignedBookings", fields: [assignedTo], references: [id])
  client          Client             @relation(fields: [clientId], references: [id])
  inquiry         Inquiry?           @relation(fields: [inquiryId], references: [id])
  location        Location           @relation(fields: [locationId], references: [id])
  model           Model              @relation(fields: [modelId], references: [id])
  fraudSignals    FraudSignal[]
  incidents       Incident[]
  lostRevenue     LostRevenueEntry[]
  payments        Payment[]
  reviews         Review[]

  @@index([clientId])
  @@index([modelId])
  @@index([status])
  @@index([startAt])
  @@index([modelId, startAt])
  @@index([clientId, createdAt])
  @@index([status, startAt])
  @@index([assignedTo, status])
  @@map("bookings")
}

model BookingService {
  bookingId String
  serviceId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([bookingId, serviceId])
  @@map("booking_services")
}

model BookingTimeline {
  id        String   @id @default(cuid())
  bookingId String
  eventType String
  payload   Json
  createdBy String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@map("booking_timeline")
}

model AvailabilityRule {
  id         String   @id @default(cuid())
  name       String
  scope      String
  locationId String?
  modelId    String?
  rule       Json
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("availability_rules")
}

model AvailabilitySlot {
  id         String    @id @default(cuid())
  modelId    String
  startAt    DateTime
  endAt      DateTime
  status     String    @default("available")
  source     String    @default("manual")
  confidence Float     @default(1.0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  date       DateTime?
  note       String?
  timeFrom   String?
  timeTo     String?
  type       String?
  model      Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId, startAt])
  @@index([status, startAt])
  @@index([modelId, date])
  @@map("availability_slots")
}

model AvailabilityMismatch {
  id             String    @id @default(cuid())
  modelId        String
  expectedStatus String
  actualStatus   String
  detectedAt     DateTime
  severity       String
  context        Json
  resolvedAt     DateTime?
  model          Model     @relation(fields: [modelId], references: [id])

  @@index([detectedAt])
  @@index([modelId, resolvedAt])
  @@map("availability_mismatches")
}

model Task {
  id            String    @id @default(cuid())
  type          String
  status        String    @default("open")
  priority      String    @default("normal")
  subject       String
  entityType    String
  entityId      String
  assignedTo    String?
  dueAt         DateTime?
  slaDeadlineAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedUser  User?     @relation("AssignedTasks", fields: [assignedTo], references: [id])

  @@index([assignedTo, status])
  @@index([status, slaDeadlineAt])
  @@index([entityType, entityId])
  @@map("tasks")
}

model Exception {
  id         String    @id @default(cuid())
  type       String
  status     String    @default("open")
  severity   String
  entityType String
  entityId   String
  summary    String
  details    Json
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, severity])
  @@index([entityType, entityId])
  @@map("exceptions")
}

model SLAPolicy {
  id              String      @id @default(cuid())
  name            String
  appliesTo       String
  key             String
  deadlineMinutes Int
  escalation      Json
  status          String      @default("active")
  records         SLARecord[]

  @@map("sla_policies")
}

model Payment {
  id                String    @id @default(cuid())
  bookingId         String?
  provider          String?
  providerPaymentId String?
  type              String?
  status            String    @default("pending")
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("GBP")
  failureReason     String?
  refundedAmount    Decimal?  @db.Decimal(12, 2)
  refundedAt        DateTime?
  raw               Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  clientId          String?
  createdById       String?
  method            String?
  modelId           String?
  notes             String?
  receivedAt        DateTime?
  reference         String?
  stripePaymentId   String?
  booking           Booking?  @relation(fields: [bookingId], references: [id])
  client            Client?   @relation(fields: [clientId], references: [id])
  createdBy         User?     @relation("CreatedPayments", fields: [createdById], references: [id])
  model             Model?    @relation(fields: [modelId], references: [id])

  @@unique([provider, providerPaymentId])
  @@index([bookingId])
  @@index([clientId])
  @@index([modelId])
  @@index([status])
  @@map("payments")
}

model Integration {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  type        String
  status      String       @default("active")
  config      Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  webhooksIn  WebhookIn[]
  webhooksOut WebhookOut[]

  @@map("integrations")
}

model WebhookIn {
  id             String      @id @default(cuid())
  integrationId  String
  eventType      String
  headers        Json
  payload        Json
  receivedAt     DateTime    @default(now())
  processedAt    DateTime?
  status         String      @default("received")
  error          String?
  idempotencyKey String?
  integration    Integration @relation(fields: [integrationId], references: [id])

  @@unique([integrationId, idempotencyKey])
  @@index([integrationId, receivedAt])
  @@index([status, receivedAt])
  @@map("webhooks_in")
}

model WebhookOut {
  id            String      @id @default(cuid())
  integrationId String
  eventType     String
  targetUrl     String
  payload       Json
  createdAt     DateTime    @default(now())
  sentAt        DateTime?
  status        String      @default("pending")
  attempts      Int         @default(0)
  lastError     String?
  integration   Integration @relation(fields: [integrationId], references: [id])

  @@index([status, createdAt])
  @@map("webhooks_out")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorType   String   @default("user")
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_log")
}

model DomainEvent {
  id          String    @id @default(cuid())
  eventType   String
  entityType  String
  entityId    String
  payload     Json
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@index([eventType, createdAt])
  @@index([publishedAt])
  @@map("domain_events")
}

model AutomationRule {
  id         String                @id @default(cuid())
  name       String
  status     String                @default("active")
  trigger    String
  conditions Json
  actions    Json
  limits     Json?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  executions AutomationExecution[]

  @@map("automation_rules")
}

model AutomationExecution {
  id         String         @id @default(cuid())
  ruleId     String
  eventId    String
  status     String         @default("running")
  startedAt  DateTime       @default(now())
  finishedAt DateTime?
  logs       Json?
  rule       AutomationRule @relation(fields: [ruleId], references: [id])

  @@unique([ruleId, eventId])
  @@map("automation_executions")
}

model ModelApplication {
  id              String   @id @default(cuid())
  source          String   @default("self")
  status          String   @default("new")
  name            String
  age             Int?
  height          Int?
  weight          Int?
  dressSizeUK     String?
  feetSizeUK      String?
  breastSize      String?
  breastType      String?
  eyesColour      String?
  hairColour      String?
  smokingStatus   String?
  tattooStatus    String?
  piercingTypes   String?
  nationality     String?
  languages       String[]
  orientation     String?
  workWithCouples Boolean  @default(false)
  workWithWomen   Boolean  @default(false)
  rate30min       Int?
  rate45min       Int?
  rate1hIn        Int?
  rate1hOut       Int?
  rate90minIn     Int?
  rate90minOut    Int?
  rate2hIn        Int?
  rate2hOut       Int?
  rateExtraHour   Int?
  rateOvernight   Int?
  blackClients    Boolean  @default(true)
  disabledClients Boolean  @default(true)
  addressStreet   String?
  addressFlat     String?
  addressPostcode String?
  tubeStation     String?
  airportHeathrow Boolean  @default(false)
  airportGatwick  Boolean  @default(false)
