  id          String   @id @default(cuid())
  type        String   // restaurant | hotel | chauffeur | flowers | gifts
  name        String
  districtId  String?
  address     String?
  website     String?
  phone       String?
  description String?  @db.Text
  priceRange  String?  // "££££"
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([districtId])
  @@map("concierge_partners")
}

// ============================================
// PHASE 2 — BLOG / EDITORIAL
// ============================================

model BlogPost {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  excerpt          String?   @db.Text
  content          String    @db.Text
  coverImage       String?
  category         String    // guide | lifestyle | london | news
  tags             String[]
  seoTitle         String?
  seoDescription   String?
  publishedAt      DateTime?
  isPublished      Boolean   @default(false)
  authorName       String?
  relatedDistricts String[]
  relatedServices  String[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@map("blog_posts")
}
